# Copy to backend.hcl and adjust after running bootstrap:
#   cp backend.hcl.example backend.hcl
#   terraform init -backend-config=../../backend.hcl
#
# Bucket name comes from bootstrap output: quantumbank-tf-state-<account_id>

bucket         = "quantumbank-tf-state-577137986953"
region         = "ap-south-1"
dynamodb_table = "quantumbank-tf-locks"
